    <dc:title>The Effects of Oral Contraceptives on Exercise Performance in Women: A Systematic Review and Meta-analysis</dc:title>
    <dc:date>2020</dc:date>
    <prism:volume>50</prism:volume>
    <prism:number>10</prism:number>
    <bib:pages>1785-1812</bib:pages>
    <dc:identifier>DOI 10.1007/s40279-020-01317-5</dc:identifier>
    <dc:subject>folder:Meta-Analyses</dc:subject>
    <dc:subject>folder:Hormonal Contraception</dc:subject>
    <dc:subject>focus:Impacts of the cycle on performance + mitigations</dc:subject>
    <dc:subject>tier:T1</dc:subject>
    <dc:subject>grade:MA</dc:subject>
    <dc:description>Companion MA: OC use may trivially reduce performance vs. natural cycle; most studies low quality/underpowered.</dc:description>
  </bib:Article>
  <bib:Article rdf:about="#item_3">
    <z:itemType>journalArticle</z:itemType>
