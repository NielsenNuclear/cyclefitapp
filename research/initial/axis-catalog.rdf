    <dc:title>The Effects of Menstrual Cycle Phase on Exercise Performance in Eumenorrheic Women: A Systematic Review and Meta-Analysis</dc:title>
    <dc:date>2020</dc:date>
    <prism:volume>50</prism:volume>
    <prism:number>10</prism:number>
    <bib:pages>1813-1827</bib:pages>
    <dc:identifier>DOI 10.1007/s40279-020-01319-3</dc:identifier>
    <dc:subject>folder:Meta-Analyses</dc:subject>
    <dc:subject>folder:Exercise Performance</dc:subject>
    <dc:subject>focus:Impacts of the cycle on performance + mitigations</dc:subject>
    <dc:subject>tier:T1</dc:subject>
    <dc:subject>grade:MA</dc:subject>
    <dc:description>Central anchor: pooled effect of MC phase on performance is trivial; large between-study variance. Grounds the &#x27;weak/inconsistent phase effect&#x27; thesis.</dc:description>
  </bib:Article>
