      </foaf:Person></rdf:li>
    </rdf:Seq></bib:authors>
    <dc:title>Current evidence shows no influence of women&#x27;s menstrual cycle phase on acute strength performance or adaptations to resistance exercise training</dc:title>
    <dc:date>2023</dc:date>
    <prism:volume>5</prism:volume>
    <bib:pages>1054542</bib:pages>
    <dc:identifier>DOI 10.3389/fspor.2023.1054542</dc:identifier>
    <dc:subject>folder:Systematic Reviews</dc:subject>
    <dc:subject>folder:Resistance Training</dc:subject>
    <dc:subject>focus:Adaptive training for women</dc:subject>
    <dc:subject>focus:Adaptive training for the menstrual cycle</dc:subject>
    <dc:subject>tier:T1</dc:subject>
    <dc:subject>grade:SR</dc:subject>
    <dc:description>Argues phase does not meaningfully affect acute strength or RT adaptation; critiques methodology of pro-phase studies.</dc:description>
  </bib:Article>
